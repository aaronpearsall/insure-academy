# InsureAcademy - Environment Variables
# Copy to .env and fill in your values
# Values are loaded automatically via python-dotenv when available

# Session security (required for production)
SECRET_KEY=your-secret-key-here

# Legacy login (optional - for backward compatibility)
APP_USERNAME=aaron
APP_PASSWORD=insagent2025

# Database (optional - defaults to sqlite:///insure_academy.db)
# DATABASE_URL=sqlite:///insure_academy.db

# Google OAuth (for Sign in with Google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Stripe (for subscriptions)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_ID=
STRIPE_PRICE_ANNUAL_ID=
STRIPE_WEBHOOK_SECRET=

# Flask (optional)
# PORT=5001
# FLASK_DEBUG=False
